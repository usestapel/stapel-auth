    {
      "key": "AUTH_LOGIN_GRANT",
      "kind": "bool",
      "default": false,
      "group": "auth.login",
      "gates": {
        "operations": [
          "auth_api_v1_grant_exchange_create"
        ],
        "co_gates": [],
        "behavior": "When on, POST /grant/exchange/ trades a token minted by the auth.issue_login_grant comm function for a JWT session; a grant minted with create_if_missing provisions an email account with a verified address and no usable password."
      },
      "curated": {
        "summary": "Trusted modules (e.g. the workspaces invite flow) mint a short-lived single-use grant token through an internal call; exchanging it signs the user in and can auto-create a verified account. Off by default.",
        "business_label": "Sign-in via a service-issued login grant"
      }
    },
