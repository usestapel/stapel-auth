      "default": true,
      "group": "auth.registration",
      "gates": {
        "operations": [
          "auth_api_v1_sso_login_retrieve",
          "auth_api_v1_sso_lookup_retrieve",
          "auth_api_v1_sso_oidc_callback_retrieve",
