{
  "module": "stapel-auth",
  "version": "0.12.0",
  "provides": "User authentication and account access: sign-up and sign-in with email or phone one-time codes, passwords, social (OAuth) accounts, corporate SSO (SAML/OIDC), magic links, QR hand-off and passkeys; guest (anonymous) access; two-factor authentication and step-up verification; session and device management with a security audit trail.",
  "axes": [
    {
      "key": "AUTH_ANONYMOUS",
      "kind": "bool",
      "default": true,
      "group": "auth.anonymous",
      "gates": {
        "operations": [
          "auth_api_v1_anonymous_create"
        ],
        "co_gates": []
      },
      "curated": {
        "summary": "Visitors get a temporary anonymous account (e.g. to browse or fill a cart) that can later be upgraded to a full account; guest data merges on upgrade.",
        "business_label": "Guest access without an account"
      }
    },
    {
      "key": "AUTH_TOTP",
      "kind": "bool",
      "default": true,
      "group": "auth.mfa",
      "gates": {
        "operations": [
          "auth_api_v1_mfa_enroll_exchange_create",
          "auth_api_v1_totp_challenge_verify_create",
          "auth_api_v1_totp_change_delayed_cancel_create",
          "auth_api_v1_totp_change_delayed_initiate_create",
          "auth_api_v1_totp_change_delayed_status_retrieve",
          "auth_api_v1_totp_disable_create",
          "auth_api_v1_totp_disable_otp_request_create",
          "auth_api_v1_totp_setup_confirm_create",
          "auth_api_v1_totp_setup_create"
        ],
        "co_gates": [
          "AUTH_PASSKEY_LOGIN"
        ]
      },
      "curated": {
        "summary": "Users can protect their account with time-based one-time codes (Google Authenticator etc.); also the factor behind step-up checks on sensitive actions.",
        "business_label": "Two-factor authentication with an authenticator app"
      }
    },
    {
      "key": "AUTH_PHONE_REGISTRATION",
      "kind": "bool",
      "default": true,
      "group": "auth.registration",
      "gates": {
        "operations": [
          "auth_api_v1_email_change_delayed_cancel_create",
          "auth_api_v1_email_change_delayed_initiate_create",
          "auth_api_v1_email_change_delayed_status_retrieve",
          "auth_api_v1_email_change_instant_request_new_create",
          "auth_api_v1_email_change_instant_request_old_create",
          "auth_api_v1_email_change_instant_verify_new_create",
          "auth_api_v1_email_change_instant_verify_old_create",
          "auth_api_v1_email_request_create",
          "auth_api_v1_email_verify_create",
          "auth_api_v1_logout_create",
          "auth_api_v1_logout_retrieve",
          "auth_api_v1_me_retrieve",
          "auth_api_v1_phone_change_delayed_cancel_create",
          "auth_api_v1_phone_change_delayed_initiate_create",
          "auth_api_v1_phone_change_delayed_status_retrieve",
          "auth_api_v1_phone_change_instant_request_new_create",
          "auth_api_v1_phone_change_instant_request_old_create",
          "auth_api_v1_phone_change_instant_verify_new_create",
          "auth_api_v1_phone_change_instant_verify_old_create",
          "auth_api_v1_phone_request_create",
          "auth_api_v1_phone_verify_create",
          "auth_api_v1_verify_create"
        ],
        "co_gates": [
          "AUTH_EMAIL_LOGIN",
          "AUTH_EMAIL_REGISTRATION",
          "AUTH_PHONE_LOGIN"
        ]
      },
      "curated": {
        "summary": "New users can create an account by confirming their phone number with a one-time SMS code.",
        "business_label": "Sign-up with a phone number"
      }
    },
    {
      "key": "AUTH_EMAIL_REGISTRATION",
      "kind": "bool",
